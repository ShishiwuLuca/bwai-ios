{
  "extends": ["development"],
  "hints": {
    "compat-api/html": [
      "default",
      {
        "ignore": ["meta[name=theme-color]"]
      }
    ],
    "meta-viewport": "off",
    "meta-charset-utf-8": "off",
    "highest-available-document-mode": "off",
    "manifest-file-extension": "off",
    "no-inline-styles": "off"
  }
}
