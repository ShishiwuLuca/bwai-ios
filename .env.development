# 开发环境
NODE_ENV = 'development'

# 网站标题
VITE_GLOB_APP_TITLE = BWAI

# 简称，用于配置文件名字 不要出现空格、数字开头等特殊字符
VITE_GLOB_APP_SHORT_NAME = exchange_bwai

# 资源公共路径,需要以 /开头和结尾（history 路由推荐使用 /）
VITE_PUBLIC_PATH = /

# 版本号
VITE_GLOB_SYSTEM_VERSION = 1.0.3

# 行情 WS 须指向实际网关；页面域名（如 fundexh5）常未挂 /infra/market/spot，会连接失败。可改 .env.local 覆盖。
VITE_WS_FIXED_ORIGIN = wss://fundexh5.etbit.vip

# 接口地址
# 如果没有跨域问题，直接在这里配置即可
VITE_GLOB_API_URL =

# 文件上传接口  可选
VITE_GLOB_UPLOAD_URL =

# 接口地址前缀，有些系统所有接口地址都有前缀，可以在这里统一加，方便切换
VITE_GLOB_API_URL_PREFIX = /app-api

# 是否清除console
VITE_DROP_CONSOLE = false

# 是否加密  true 为加密 false 为不加密
VITE_GLOB_ENCRYPT = false

# 加密密钥
VITE_GLOB_PUBLICKEY = 'MFwwDQYJKoZIhvcNAQEBBQADSwAwSAJBALhZATk67U53ZnVAloLzNh8RV15Pe0V9ZDQUAtpuFbgyvn/CrYSGiz0gQmiJiniGzOpP+1l1vxxrKwv/6Xmt0OkCAwEAAQ=='

# 本地开发代理，可以解决跨域及多地址代理
# 如果接口地址匹配到，则会转发到http://localhost:3000，防止本地出现跨域问题
# 可以有多个，注意多个不能换行，否则代理将会失效
VITE_GLOB_PROXY = [['/app-api','https://fundexh5.etbit.vip'],['/UploadFile','https://fundexh5.etbit.vip']]

# 服务端下发的语言包若在 S3 且未对浏览器配 CORS，开发时填桶的 origin，请求会改走 Vite 同源代理 /dev-locale-s3
VITE_DEV_LOCALE_S3_ORIGIN = https://tradingonline.s3.ap-southeast-1.amazonaws.com
