{
  "name": "bwai",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host --open",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "cross-env NODE_ENV=production NODE_OPTIONS=--max-old-space-size=24576 vite build && esno ./build/script/postBuild.ts",
    "build-only:app": "cross-env NODE_ENV=production NODE_OPTIONS=--max-old-space-size=24576 vite build --mode app && esno ./build/script/postBuild.ts",
    "build:test": "cross-env NODE_ENV=production NODE_OPTIONS=--max-old-space-size=24576 vite build --mode test && esno ./build/script/postBuild.ts",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "reinstall": "rimraf pnpm-lock.yaml && rimraf package-lock.json && rimraf components.d.ts && rimraf node_modules",
    "postinstall": "node scripts/patchCapacitorFileTransferAndroid.mjs",
    "format": "prettier --write --experimental-cli src/",
    "cap:sync": "cap sync",
    "cap:android": "cap sync android && cap open android",
    "cap:ios": "cap sync ios && cap open ios",
    "build:ios": "pnpm run build-only:app && pnpm cap:ios",
    "build:ios:release": "pnpm run build-only:app && cap sync ios && esno ./build/script/buildIos.ts release",
    "build:ios:ipa": "esno ./build/script/buildIos.ts release",
    "build:cap": "pnpm build && cap sync",
    "build:android": "pnpm run build-only:app && cap sync android && esno ./build/script/buildAndroid.ts debug",
    "build:android:release": "pnpm run build-only:app && cap sync android && esno ./build/script/buildAndroid.ts release",
    "build:android:bundle": "pnpm run build-only:app && cap sync android && esno ./build/script/buildAndroid.ts bundle",
    "android:gradle": "esno ./build/script/runAndroidGradle.ts",
    "android:compile": "pnpm run android:gradle -- :app:compileDebugJavaWithJavac"
  },
  "dependencies": {
    "@capacitor-community/file-opener": "catalog:",
    "@capacitor/android": "catalog:",
    "@capacitor/app": "catalog:",
    "@capacitor/app-launcher": "catalog:",
    "@capacitor/browser": "catalog:",
    "@capacitor/core": "catalog:",
