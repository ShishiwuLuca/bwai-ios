    "@capawesome/capacitor-badge": "catalog:",
    "@vant/touch-emulator": "catalog:",
    "@vant/use": "catalog:",
    "axios": "catalog:",
    "browser-image-compression": "catalog:",
    "crypto-js": "catalog:",
    "dayjs": "catalog:",
    "echarts": "catalog:",
    "fs-extra": "catalog:",
    "html2canvas": "catalog:",
    "js-md5": "catalog:",
